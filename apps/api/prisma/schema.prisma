generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  // Le "?" signifie que c'est optionnel (nullable)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt // Se met à jour tout seul à chaque modif
}
